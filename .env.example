# Example environment variables for AI-CFO-Multi-Agent
# Copy this file to `.env` and fill real values before running.

# Flask / backend
FLASK_APP=app.main
FLASK_ENV=development
SECRET_KEY=replace-with-a-random-secret
JWT_SECRET=replace-with-a-random-secret

# Database (choose one approach). The app may use SQLALCHEMY_DATABASE_URI or DATABASE_URL
# SQLite example (development):
DATABASE_URL=sqlite:///./dev.db
# Postgres example (production):
# SQLALCHEMY_DATABASE_URI=postgresql://<user>:<password>@<host>:<port>/<dbname>
SQLALCHEMY_DATABASE_URI=postgresql://postgres:postgres@localhost:5432/ai_cfo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_cfo
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Backend host/port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# External APIs / keys
OPENAI_API_KEY=
OPENAI_API_BASE_URL=

# Frontend (Vite) — used by frontend to locate backend API
VITE_API_BASE_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO

# Add any additional provider-specific keys here (SENTRY_DSN, AWS credentials, etc.)
